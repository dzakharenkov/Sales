# Database (required)
DATABASE_URL=postgresql+asyncpg://db_user:db_password@db_host:5432/db_name

# API runtime
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
BOT_LOG_FILE=logs/telegram_bot.log

# JWT (required): base64 32-byte secret
# Generate with:
# python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET_KEY=REPLACE_WITH_STRONG_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Telegram bot (required)
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
SDS_API_URL=http://127.0.0.1:8000
API_TIMEOUT=30
CACHE_TTL=3600
TIMEZONE=Asia/Tashkent

# Optional integrations
YANDEX_MAPS_API_KEY=
SENTRY_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_ENVIRONMENT=production
SENTRY_IGNORE_TELEGRAM_CONFLICT=true

# File storage
UPLOAD_DIR=/var/www/sales.zakharenkov.ru/html/photo
SITE_URL=https://sales.zakharenkov.ru
