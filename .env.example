# ===== REQUIRED =====
DATABASE_URL=postgresql+asyncpg://db_user:db_password@db_host:5432/db_name
JWT_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN

# ===== API SERVER =====
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ===== FILE STORAGE =====
UPLOAD_DIR=/var/www/sales.zakharenkov.ru/html/photo
SITE_URL=https://sales.zakharenkov.ru

# ===== EXTERNAL APIs =====
YANDEX_MAPS_API_KEY=

# ===== MONITORING =====
SENTRY_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_IGNORE_TELEGRAM_CONFLICT=true

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
BOT_LOG_FILE=logs/telegram_bot.log

# ===== SECURITY =====
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ===== BOT SETTINGS =====
SDS_API_URL=http://127.0.0.1:8000
API_TIMEOUT=30
CACHE_TTL=3600
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_MINUTES=10
TIMEZONE=Asia/Tashkent
